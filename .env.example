# Yango Fleet SaaS — Variables d'environnement
# Copier ce fichier en .env.local et remplir avec les vraies valeurs

# ── Supabase (obligatoire) ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Multi-tenancy ────────────────────────────────────────────────
# Slug utilisé sur localhost (développement)
NEXT_PUBLIC_DEFAULT_TENANT_SLUG=m3a
# Domaine racine des sous-domaines tenant (une fois acquis dans Vercel).
# Ex "fleet.mondomaine.com" → les clients auront {slug}.fleet.mondomaine.com
# Laisser vide tant que le domaine n'est pas configuré (app en mono-domaine).
NEXT_PUBLIC_ROOT_DOMAIN=
# Emails de contact affichés (CGU, confidentialité, statut)
NEXT_PUBLIC_SUPPORT_EMAIL=gueye.a66@gmail.com
NEXT_PUBLIC_PRIVACY_EMAIL=gueye.a66@gmail.com

# ── Superadmin ──────────────────────────────────────────────────
# NE PAS mettre NEXT_PUBLIC_ — cette clé ne doit JAMAIS être exposée côté client
# Générer une clé aléatoire forte : openssl rand -base64 32
SUPERADMIN_KEY=your_strong_random_superadmin_key_here

# ── Monitoring (Sentry) — https://sentry.io ─────────────────────
# DSN disponible dans Sentry → Settings → Projects → Keys
NEXT_PUBLIC_SENTRY_DSN=https://your_key@oXXXXXX.ingest.de.sentry.io/XXXXX
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=your-sentry-project-slug
# Générer sur sentry.io/settings/account/api/auth-tokens/ (scope: project:write)
SENTRY_AUTH_TOKEN=sntryu_your_auth_token_here
